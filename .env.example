# Supabase — dapatkan dari project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx

# Service role key — untuk API routes (jangan bocor ke client)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Schema — "routine_class" untuk production, "routine_class_dev" untuk development
NEXT_PUBLIC_SUPABASE_SCHEMA=routine_class

# JWT Secret — untuk sign & verify custom JWT
JWT_SECRET=your-jwt-secret-min-32-chars

# Mayar API — untuk payment invoice
MAYAR_API_KEY=mayar_api_key_xxxxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
